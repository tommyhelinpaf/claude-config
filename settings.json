      "mcp__qdrant__qdrant-find-with-ids",
      "mcp__qdrant__qdrant-delete",
      "Bash(curl -s http://127.0.0.1:6333/*)",
      "Bash(npx *)",
      "mcp__playwright__browser_navigate",
