      "Bash(gh *)",
      "Bash(docker run:*)",
      "Bash(docker ps:*)",
      "Bash(open -a Docker)",
      "Bash(python3:*)",
      "Bash(python3.12 -m venv *)",
      "Bash(pip3 *)",
      "Bash(~/qdrant-mcp-venv/bin/pip install *)",
