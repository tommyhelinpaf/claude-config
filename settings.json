  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/qdrant-sync.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "git fetch --all --quiet 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/claude-backup.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
